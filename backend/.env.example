ENVIRONMENT=dev
APP_NAME=IoT Backend API
# Comma-separated list
CORS_ORIGINS=http://localhost:3000

# MySQL connection string (use port 3306 for server hostname; Docker Compose service `db` is always 3306 inside the network)
# Example local: mysql+pymysql://root:password@localhost:3307/iot  (if you map host 3307 -> container 3306)
DATABASE_URL=mysql+pymysql://root:CHANGE_ME@localhost:3306/iot

# JWT (login session)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

